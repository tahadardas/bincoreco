# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/banco_ricco?schema=public"

# JWT
JWT_SECRET="change-me-to-a-strong-secret"
JWT_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# API
API_PORT=4000
API_PREFIX="/api"

# CORS — comma-separated origins allowed
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001,http://localhost:5173"

# Set to "false" to disable Swagger docs in production
ENABLE_SWAGGER="true"

# App
NODE_ENV="development"
